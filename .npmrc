# Hoist all packages so Next.js / Turbopack can resolve them
shamefully-hoist=true

# Don't enforce exact peer deps (some packages have loose peer ranges)
strict-peer-dependencies=false

# Network timeout settings — 5 minutes per fetch, 10 retries
fetch-timeout=300000
fetch-retry-mintimeout=30000
fetch-retry-maxtimeout=300000
fetch-retries=10
network-timeout=300000

# Suppress node engine version warning (running 22.22.3, project wants 22.21.1)
engine-strict=false

# Don't auto-run `pnpm install` before every script (pnpm v11 pre-check was
# aborting scripts with ERR_PNPM_IGNORED_BUILDS exit 1 before they could run).
verify-deps-before-run=false
