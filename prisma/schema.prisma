generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum BillingInterval {
    day
    week
    month
    year
}

enum CreditTransactionType {
    purchase
    subscriptionGrant @map("subscription_grant")
    bonus
    promo
    usage
    refund
    expire
    adjustment
}

enum InvitationStatus {
    pending
    accepted
    rejected
    canceled
}

enum LeadSource {
    website
    referral
    socialMedia @map("social_media")
    advertising
    coldCall    @map("cold_call")
    email
    event
    other
}

enum LeadStatus {
    new
    contacted
    qualified
    proposal
    negotiation
    won
    lost
}

enum MemberRole {
    owner
    admin
    member
}

enum OrderStatus {
    pending
    completed
    failed
    refunded
    partiallyRefunded @map("partially_refunded")
}

enum OrderType {
    subscription
    oneTime      @map("one_time")
}

enum PriceModel {
    flat
    perSeat @map("per_seat")
    metered
}

enum PriceType {
    recurring
    oneTime   @map("one_time")
}

enum SubscriptionStatus {
    active
    canceled
    incomplete
    incomplete_expired
    past_due
    paused
    trialing
    unpaid
}

enum UserRole {
    user
    admin
}

model Account {
    id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    accountId             String    @map("account_id") @db.Text
    providerId            String    @map("provider_id") @db.Text
    userId                String    @map("user_id") @db.Uuid
    accessToken           String?   @map("access_token") @db.Text
    refreshToken          String?   @map("refresh_token") @db.Text
    idToken               String?   @map("id_token") @db.Text
    expiresAt             DateTime? @map("expires_at") @db.Timestamptz(6)
    password              String?   @db.Text
    accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
    refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
    scope                 String?   @db.Text
    createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([providerId, accountId], map: "account_provider_account_idx")
    @@index([userId], map: "account_user_id_idx")
    @@map("account")
}

model AiChat {
    id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String?  @map("organization_id") @db.Uuid
    userId         String?  @map("user_id") @db.Uuid
    title          String?  @db.Text
    messages       String?  @db.Text
    pinned         Boolean  @default(false)
    createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
    studyPlans   StudyPlan[]

    @@index([organizationId], map: "ai_chat_organization_id_idx")
    @@index([userId], map: "ai_chat_user_id_idx")
    @@index([createdAt], map: "ai_chat_created_at_idx")
    @@map("ai_chat")
}

model BillingEvent {
    id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String?  @map("organization_id") @db.Uuid
    stripeEventId  String   @unique(map: "billing_event_stripe_event_id_unique") @map("stripe_event_id") @db.Text
    eventType      String   @map("event_type") @db.Text
    subscriptionId String?  @map("subscription_id") @db.Text
    orderId        String?  @map("order_id") @db.Uuid
    eventData      String?  @map("event_data") @db.Text
    processed      Boolean  @default(true)
    error          String?  @db.Text
    createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

    @@index([organizationId], map: "billing_event_organization_id_idx")
    @@index([eventType], map: "billing_event_event_type_idx")
    @@index([subscriptionId], map: "billing_event_subscription_id_idx")
    @@index([createdAt], map: "billing_event_created_at_idx")
    @@map("billing_event")
}

model CreditBalance {
    id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId    String   @unique(map: "credit_balance_organization_id_unique") @map("organization_id") @db.Uuid
    balance           Int      @default(0)
    lifetimePurchased Int      @default(0) @map("lifetime_purchased")
    lifetimeGranted   Int      @default(0) @map("lifetime_granted")
    lifetimeUsed      Int      @default(0) @map("lifetime_used")
    lifetimeExpired   Int      @default(0) @map("lifetime_expired")
    createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    @@index([organizationId], map: "credit_balance_organization_id_idx")
    @@map("credit_balance")
}

model CreditDeductionFailure {
    id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId  String    @map("organization_id") @db.Uuid
    amount          Int
    errorCode       String    @map("error_code") @db.Text
    errorMessage    String?   @map("error_message") @db.Text
    model           String?   @db.Text
    inputTokens     Int?      @map("input_tokens")
    outputTokens    Int?      @map("output_tokens")
    referenceType   String?   @map("reference_type") @db.Text
    referenceId     String?   @map("reference_id") @db.Text
    userId          String?   @map("user_id") @db.Uuid
    resolved        Boolean   @default(false)
    resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz(6)
    resolvedBy      String?   @map("resolved_by") @db.Uuid
    resolutionNotes String?   @map("resolution_notes") @db.Text
    createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    user           User?        @relation("DeductionFailureUser", fields: [userId], references: [id], onDelete: SetNull)
    resolvedByUser User?        @relation("DeductionFailureResolvedBy", fields: [resolvedBy], references: [id], onDelete: SetNull)

    @@index([organizationId], map: "credit_deduction_failure_org_idx")
    @@index([resolved], map: "credit_deduction_failure_resolved_idx")
    @@index([createdAt], map: "credit_deduction_failure_created_idx")
    @@map("credit_deduction_failure")
}

model CreditTransaction {
    id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String                @map("organization_id") @db.Uuid
    type           CreditTransactionType
    amount         Int
    balanceAfter   Int                   @map("balance_after")
    description    String?               @db.Text
    referenceType  String?               @map("reference_type") @db.Text
    referenceId    String?               @map("reference_id") @db.Text
    model          String?               @db.Text
    inputTokens    Int?                  @map("input_tokens")
    outputTokens   Int?                  @map("output_tokens")
    createdBy      String?               @map("created_by") @db.Uuid
    metadata       String?               @db.Text
    createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

    organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    createdByUser User?        @relation("CreditTransactionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

    @@index([organizationId], map: "credit_transaction_organization_id_idx")
    @@index([type], map: "credit_transaction_type_idx")
    @@index([createdAt], map: "credit_transaction_created_at_idx")
    @@index([referenceType, referenceId], map: "credit_transaction_reference_idx")
    @@index([organizationId, createdAt], map: "credit_transaction_org_created_idx")
    @@index([organizationId, type], map: "credit_transaction_org_type_idx")
    @@map("credit_transaction")
}

model Invitation {
    id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String           @map("organization_id") @db.Uuid
    email          String           @db.Text
    role           MemberRole       @default(member)
    status         InvitationStatus @default(pending)
    expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
    inviterId      String           @map("inviter_id") @db.Uuid
    createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    inviter      User         @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)

    @@index([organizationId], map: "invitation_organization_id_idx")
    @@index([email], map: "invitation_email_idx")
    @@index([status], map: "invitation_status_idx")
    @@index([expiresAt], map: "invitation_expires_at_idx")
    @@index([inviterId], map: "invitation_inviter_id_idx")
    @@map("invitation")
}

model Lead {
    id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String     @map("organization_id") @db.Uuid
    firstName      String     @map("first_name") @db.Text
    lastName       String     @map("last_name") @db.Text
    email          String     @db.Text
    phone          String?    @db.Text
    company        String?    @db.Text
    jobTitle       String?    @map("job_title") @db.Text
    status         LeadStatus @default(new)
    source         LeadSource @default(other)
    estimatedValue Int?       @map("estimated_value")
    notes          String?    @db.Text
    assignedToId   String?    @map("assigned_to_id") @db.Uuid
    createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    assignedTo   User?        @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

    @@index([organizationId], map: "lead_organization_id_idx")
    @@index([status], map: "lead_status_idx")
    @@index([source], map: "lead_source_idx")
    @@index([assignedToId], map: "lead_assigned_to_id_idx")
    @@index([email], map: "lead_email_idx")
    @@index([createdAt], map: "lead_created_at_idx")
    @@index([organizationId, status], map: "lead_org_status_idx")
    @@map("lead")
}

model Member {
    id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String     @map("organization_id") @db.Uuid
    userId         String     @map("user_id") @db.Uuid
    role           MemberRole @default(member)
    createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, organizationId], map: "member_user_org_idx")
    @@index([organizationId], map: "member_organization_id_idx")
    @@index([userId], map: "member_user_id_idx")
    @@index([role], map: "member_role_idx")
    @@map("member")
}

model Order {
    id                      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId          String      @map("organization_id") @db.Uuid
    stripeCustomerId        String      @map("stripe_customer_id") @db.Text
    stripePaymentIntentId   String?     @map("stripe_payment_intent_id") @db.Text
    stripeCheckoutSessionId String?     @map("stripe_checkout_session_id") @db.Text
    totalAmount             Int         @map("total_amount")
    currency                String      @default("usd") @db.Text
    status                  OrderStatus @default(completed)
    createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    items        OrderItem[]

    @@index([organizationId], map: "order_organization_id_idx")
    @@index([stripeCustomerId], map: "order_stripe_customer_id_idx")
    @@index([status], map: "order_status_idx")
    @@index([stripePaymentIntentId], map: "order_payment_intent_id_idx")
    @@index([stripeCheckoutSessionId], map: "order_checkout_session_id_idx")
    @@map("order")
}

model OrderItem {
    id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    orderId         String   @map("order_id") @db.Uuid
    stripePriceId   String   @map("stripe_price_id") @db.Text
    stripeProductId String?  @map("stripe_product_id") @db.Text
    quantity        Int      @default(1)
    unitAmount      Int      @map("unit_amount")
    totalAmount     Int      @map("total_amount")
    description     String?  @db.Text
    createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@index([orderId], map: "order_item_order_id_idx")
    @@index([stripePriceId], map: "order_item_stripe_price_id_idx")
    @@map("order_item")
}

model Organization {
    id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    name             String   @db.Text
    slug             String?  @db.Text
    logo             String?  @db.Text
    metadata         String?  @db.Text
    stripeCustomerId String?  @map("stripe_customer_id") @db.Text
    createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    members                 Member[]
    invitations             Invitation[]
    subscriptions           Subscription[]
    orders                  Order[]
    billingEvents           BillingEvent[]
    aiChats                 AiChat[]
    leads                   Lead[]
    creditBalance           CreditBalance?
    creditTransactions      CreditTransaction[]
    creditDeductionFailures CreditDeductionFailure[]
    courses                 Course[]
    enrollments             Enrollment[]
    materials               Material[]
    topics                  Topic[]
    quizzes                 Quiz[]
    questions               Question[]
    quizAttempts            QuizAttempt[]
    answers                 Answer[]
    studyPlans              StudyPlan[]
    studyPlanItems          StudyPlanItem[]
    performanceLogs         PerformanceLog[]

    @@unique([slug], map: "organization_slug_idx")
    @@index([name], map: "organization_name_idx")
    @@index([stripeCustomerId], map: "organization_stripe_customer_id_idx")
    @@map("organization")
}

model Session {
    id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    expiresAt            DateTime @map("expires_at") @db.Timestamptz(6)
    ipAddress            String?  @map("ip_address") @db.Text
    userAgent            String?  @map("user_agent") @db.Text
    userId               String   @map("user_id") @db.Uuid
    impersonatedBy       String?  @map("impersonated_by") @db.Uuid
    activeOrganizationId String?  @map("active_organization_id") @db.Uuid
    token                String   @db.Text
    createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    user               User  @relation("SessionUser", fields: [userId], references: [id], onDelete: Cascade)
    impersonatedByUser User? @relation("SessionImpersonatedBy", fields: [impersonatedBy], references: [id])

    @@unique([token], map: "session_token_idx")
    @@index([userId], map: "session_user_id_idx")
    @@index([expiresAt], map: "session_expires_at_idx")
    @@index([activeOrganizationId], map: "session_active_organization_id_idx")
    @@map("session")
}

model Subscription {
    id                 String             @id @db.Text
    organizationId     String             @map("organization_id") @db.Uuid
    stripeCustomerId   String             @map("stripe_customer_id") @db.Text
    status             SubscriptionStatus
    stripePriceId      String             @map("stripe_price_id") @db.Text
    stripeProductId    String?            @map("stripe_product_id") @db.Text
    quantity           Int                @default(1)
    interval           BillingInterval
    intervalCount      Int                @default(1) @map("interval_count")
    unitAmount         Int?               @map("unit_amount")
    currency           String             @default("usd") @db.Text
    currentPeriodStart DateTime           @map("current_period_start") @db.Timestamptz(6)
    currentPeriodEnd   DateTime           @map("current_period_end") @db.Timestamptz(6)
    trialStart         DateTime?          @map("trial_start") @db.Timestamptz(6)
    trialEnd           DateTime?          @map("trial_end") @db.Timestamptz(6)
    cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
    canceledAt         DateTime?          @map("canceled_at") @db.Timestamptz(6)
    createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    items        SubscriptionItem[]

    @@index([organizationId], map: "subscription_organization_id_idx")
    @@index([stripeCustomerId], map: "subscription_stripe_customer_id_idx")
    @@index([status], map: "subscription_status_idx")
    @@index([stripePriceId], map: "subscription_stripe_price_id_idx")
    @@index([organizationId, status], map: "subscription_org_status_idx")
    @@map("subscription")
}

model SubscriptionItem {
    id              String           @id @db.Text
    subscriptionId  String           @map("subscription_id") @db.Text
    stripePriceId   String           @map("stripe_price_id") @db.Text
    stripeProductId String?          @map("stripe_product_id") @db.Text
    quantity        Int              @default(1)
    priceAmount     Int?             @map("price_amount")
    priceType       PriceType        @default(recurring) @map("price_type")
    priceModel      PriceModel       @default(flat) @map("price_model")
    interval        BillingInterval?
    intervalCount   Int?             @default(1) @map("interval_count")
    meterId         String?          @map("meter_id") @db.Text
    createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

    @@index([subscriptionId], map: "subscription_item_subscription_id_idx")
    @@index([stripePriceId], map: "subscription_item_stripe_price_id_idx")
    @@index([priceModel], map: "subscription_item_price_model_idx")
    @@map("subscription_item")
}

model TwoFactor {
    id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    secret      String   @db.Text
    backupCodes String   @map("backup_codes") @db.Text
    userId      String   @map("user_id") @db.Uuid
    createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId], map: "two_factor_user_id_idx")
    @@map("two_factor")
}

model User {
    id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    name               String
    email              String    @unique(map: "user_email_unique") @db.Text
    emailVerified      Boolean   @default(false) @map("email_verified")
    image              String?   @db.Text
    username           String?   @unique(map: "user_username_unique") @db.Text
    role               UserRole  @default(user)
    banned             Boolean?  @default(false)
    banReason          String?   @map("ban_reason") @db.Text
    banExpires         DateTime? @map("ban_expires") @db.Timestamptz(6)
    onboardingComplete Boolean   @default(false) @map("onboarding_complete")
    twoFactorEnabled   Boolean?  @default(false) @map("two_factor_enabled")
    currentStreak      Int       @default(0) @map("current_streak")
    longestStreak      Int       @default(0) @map("longest_streak")
    lastActiveDate     DateTime? @map("last_active_date") @db.Date
    createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    accounts                        Account[]
    sessions                        Session[]                @relation("SessionUser")
    impersonatedSessions            Session[]                @relation("SessionImpersonatedBy")
    memberships                     Member[]
    invitations                     Invitation[]             @relation("InvitationInviter")
    twoFactors                      TwoFactor[]
    aiChats                         AiChat[]
    assignedLeads                   Lead[]                   @relation("LeadAssignedTo")
    creditTransactionsCreated       CreditTransaction[]      @relation("CreditTransactionCreatedBy")
    creditDeductionFailures         CreditDeductionFailure[] @relation("DeductionFailureUser")
    creditDeductionFailuresResolved CreditDeductionFailure[] @relation("DeductionFailureResolvedBy")
    coursesCreated                  Course[]                 @relation("CourseCreatedBy")
    enrollments                     Enrollment[]             @relation("EnrollmentUser")
    materialsUploaded               Material[]               @relation("MaterialUploadedBy")
    quizzesCreated                  Quiz[]                   @relation("QuizCreatedBy")
    quizAttempts                    QuizAttempt[]            @relation("AttemptUser")
    answers                         Answer[]                 @relation("AnswerUser")
    studyPlans                      StudyPlan[]              @relation("StudyPlanUser")
    performanceLogs                 PerformanceLog[]         @relation("PerformanceLogUser")

    @@index([role], map: "user_role_idx")
    @@index([banned], map: "user_banned_idx")
    @@map("user")
}

model Verification {
    id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    identifier String    @db.Text
    value      String    @db.Text
    expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
    createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    @@index([identifier], map: "verification_identifier_idx")
    @@index([value], map: "verification_value_idx")
    @@index([expiresAt], map: "verification_expires_at_idx")
    @@map("verification")
}

// =============================================================================
// LEARNING TUTOR AGENT
// Adaptive learning models: courses, materials, topics, quizzes, attempts,
// study plans, and performance tracking. All org-scoped (multi-tenant).
// =============================================================================

enum CourseLevel {
    beginner
    intermediate
    advanced
}

enum CourseStatus {
    draft
    published
    archived
}

enum EnrollmentRole {
    student
    instructor
}

enum MaterialType {
    pdf
    docx
    txt
    note
    link
}

enum MaterialStatus {
    uploaded
    processing
    ready
    failed
}

enum QuizDifficulty {
    easy
    medium
    hard
}

/**
 * What a set of questions is FOR. Both are served by the same adaptive engine;
 * they differ in presentation, not mechanism.
 *   assessment — measures you. Difficulty hidden, marks withheld until the end.
 *   revision   — teaches you. Marks and model answers shown after every answer.
 */
enum QuizPurpose {
    assessment
    revision
}

enum QuizStatus {
    draft
    published
    archived
}

enum QuestionType {
    multipleChoice
    trueFalse
    shortAnswer
    longAnswer
}

enum AttemptStatus {
    inProgress
    submitted
    graded
}

enum StudyPlanStatus {
    active
    completed
    paused
    archived
}

enum StudyPlanItemStatus {
    pending
    inProgress
    completed
    skipped
}

enum PerformanceEventType {
    lessonViewed
    lessonCompleted
    quizStarted
    quizCompleted
    materialViewed
    chatAsked
    planItemCompleted
    login
}

model Course {
    id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String       @map("organization_id") @db.Uuid
    createdById    String?      @map("created_by_id") @db.Uuid
    title          String
    description    String?
    subject        String?
    level          CourseLevel  @default(beginner)
    status         CourseStatus @default(draft)
    coverImage     String?      @map("cover_image")
    createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    createdBy    User?        @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
    materials    Material[]
    topics       Topic[]
    quizzes      Quiz[]
    enrollments  Enrollment[]
    studyPlans   StudyPlan[]

    @@index([organizationId])
    @@index([organizationId, status])
    @@index([createdById])
    @@map("course")
}

model Enrollment {
    id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String         @map("organization_id") @db.Uuid
    courseId       String         @map("course_id") @db.Uuid
    userId         String         @map("user_id") @db.Uuid
    role           EnrollmentRole @default(student)
    progress       Int            @default(0)
    enrolledAt     DateTime       @default(now()) @map("enrolled_at") @db.Timestamptz(3)
    createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
    user         User         @relation("EnrollmentUser", fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, courseId])
    @@index([organizationId])
    @@index([courseId])
    @@index([userId])
    @@map("enrollment")
}

model Material {
    id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String         @map("organization_id") @db.Uuid
    courseId       String         @map("course_id") @db.Uuid
    uploadedById   String?        @map("uploaded_by_id") @db.Uuid
    title          String
    fileUrl        String?        @map("file_url")
    fileType       MaterialType   @default(pdf) @map("file_type")
    fileSizeBytes  Int?           @map("file_size_bytes")
    extractedText  String?        @map("extracted_text")
    status         MaterialStatus @default(uploaded)
    errorMessage   String?        @map("error_message")
    createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
    uploadedBy   User?        @relation("MaterialUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
    topics       Topic[]

    @@index([organizationId])
    @@index([courseId])
    @@index([organizationId, status])
    @@map("material")
}

model Topic {
    id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId   String   @map("organization_id") @db.Uuid
    courseId         String   @map("course_id") @db.Uuid
    materialId       String?  @map("material_id") @db.Uuid
    title            String
    summary          String?
    content          String?
    orderIndex       Int      @default(0) @map("order_index")
    estimatedMinutes Int?     @map("estimated_minutes")
    createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
    material        Material?        @relation(fields: [materialId], references: [id], onDelete: SetNull)
    quizzes         Quiz[]
    questions       Question[]
    performanceLogs PerformanceLog[]
    studyPlanItems  StudyPlanItem[]

    @@index([organizationId])
    @@index([courseId])
    @@index([courseId, orderIndex])
    @@map("topic")
}

model Quiz {
    id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId   String         @map("organization_id") @db.Uuid
    courseId         String         @map("course_id") @db.Uuid
    topicId          String?        @map("topic_id") @db.Uuid
    createdById      String?        @map("created_by_id") @db.Uuid
    title            String
    description      String?
    difficulty       QuizDifficulty @default(medium)
    // Assessment vs revision. Distinguishing these by shape (topicId == null,
    // all-written questions) was guesswork that mixed Q&A sets and course-wide
    // assessments together in both listings.
    purpose          QuizPurpose    @default(assessment)
    // An adaptive quiz serves one question at a time, choosing each from a
    // mixed-difficulty pool based on live performance. `difficulty` above is then
    // only a nominal summary — the real level varies per Question.
    isAdaptive       Boolean        @default(false) @map("is_adaptive")
    // How many of the pooled questions an adaptive attempt actually serves. The
    // pool is deliberately larger so the engine has room to choose; without this
    // there is no way to tell "quiz length" from "pool size".
    adaptiveLength   Int?           @map("adaptive_length")
    passingScore     Int            @default(60) @map("passing_score")
    timeLimitMinutes Int?           @map("time_limit_minutes")
    isAiGenerated    Boolean        @default(false) @map("is_ai_generated")
    status           QuizStatus     @default(draft)
    createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
    topic        Topic?        @relation(fields: [topicId], references: [id], onDelete: SetNull)
    createdBy    User?         @relation("QuizCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
    questions    Question[]
    attempts     QuizAttempt[]

    @@index([organizationId])
    @@index([courseId])
    @@index([topicId])
    @@index([organizationId, status])
    @@map("quiz")
}

model Question {
    id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String          @map("organization_id") @db.Uuid
    quizId         String          @map("quiz_id") @db.Uuid
    // Set on adaptive quizzes, where the pool spans several levels and topics.
    // Null on legacy rows and on fixed-difficulty quizzes, which inherit both
    // from the parent Quiz. Never shown to the student — the selection engine
    // reads it, the UI does not.
    difficulty     QuizDifficulty?
    topicId        String?         @map("topic_id") @db.Uuid
    prompt         String
    type           QuestionType    @default(multipleChoice)
    options        Json?           @db.JsonB
    correctAnswer  String          @map("correct_answer")
    explanation    String?
    points         Int             @default(1)
    orderIndex     Int             @default(0) @map("order_index")
    createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
    topic        Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
    answers      Answer[]

    @@index([organizationId])
    @@index([quizId])
    @@index([quizId, orderIndex])
    @@index([topicId])
    @@map("question")
}

model QuizAttempt {
    id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId  String        @map("organization_id") @db.Uuid
    quizId          String        @map("quiz_id") @db.Uuid
    userId          String        @map("user_id") @db.Uuid
    courseId        String?       @map("course_id") @db.Uuid
    score           Int           @default(0)
    maxScore        Int           @map("max_score")
    percentage      Float?
    passed          Boolean       @default(false)
    status          AttemptStatus @default(inProgress)
    startedAt       DateTime      @default(now()) @map("started_at") @db.Timestamptz(3)
    submittedAt     DateTime?     @map("submitted_at") @db.Timestamptz(3)
    durationSeconds Int?          @map("duration_seconds")
    createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    quiz            Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
    user            User             @relation("AttemptUser", fields: [userId], references: [id], onDelete: Cascade)
    answers         Answer[]
    performanceLogs PerformanceLog[]

    @@index([organizationId])
    @@index([quizId])
    @@index([userId])
    @@index([organizationId, userId])
    @@index([userId, quizId])
    @@map("quiz_attempt")
}

model Answer {
    id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    attemptId      String   @map("attempt_id") @db.Uuid
    questionId     String   @map("question_id") @db.Uuid
    userId         String?  @map("user_id") @db.Uuid
    responseText   String?  @map("response_text")
    responseImage  String?  @map("response_image")
    selectedOption String?  @map("selected_option")
    isCorrect      Boolean? @map("is_correct")
    pointsAwarded  Int      @default(0) @map("points_awarded")
    aiFeedback     String?  @map("ai_feedback")
    createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    attempt      QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
    question     Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
    user         User?        @relation("AnswerUser", fields: [userId], references: [id], onDelete: SetNull)

    @@unique([attemptId, questionId])
    @@index([organizationId])
    @@index([attemptId])
    @@index([questionId])
    @@map("answer")
}

model StudyPlan {
    id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String          @map("organization_id") @db.Uuid
    userId         String          @map("user_id") @db.Uuid
    courseId       String?         @map("course_id") @db.Uuid
    aiChatId       String?         @map("ai_chat_id") @db.Uuid
    title          String
    goal           String?
    status         StudyPlanStatus @default(active)
    startDate      DateTime?       @map("start_date") @db.Timestamptz(3)
    targetEndDate  DateTime?       @map("target_end_date") @db.Timestamptz(3)
    generatedByAi  Boolean         @default(true) @map("generated_by_ai")
    createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    user         User            @relation("StudyPlanUser", fields: [userId], references: [id], onDelete: Cascade)
    course       Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
    aiChat       AiChat?         @relation(fields: [aiChatId], references: [id], onDelete: SetNull)
    items        StudyPlanItem[]

    @@index([organizationId])
    @@index([userId])
    @@index([organizationId, userId])
    @@index([courseId])
    @@map("study_plan")
}

model StudyPlanItem {
    id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId String              @map("organization_id") @db.Uuid
    studyPlanId    String              @map("study_plan_id") @db.Uuid
    topicId        String?             @map("topic_id") @db.Uuid
    quizId         String?             @map("quiz_id") @db.Uuid
    title          String
    orderIndex     Int                 @default(0) @map("order_index")
    dueDate        DateTime?           @map("due_date") @db.Timestamptz(3)
    status         StudyPlanItemStatus @default(pending)
    completedAt    DateTime?           @map("completed_at") @db.Timestamptz(3)
    createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    studyPlan    StudyPlan    @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
    topic        Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)

    @@index([organizationId])
    @@index([studyPlanId])
    @@index([studyPlanId, orderIndex])
    @@map("study_plan_item")
}

model PerformanceLog {
    id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    organizationId  String               @map("organization_id") @db.Uuid
    userId          String               @map("user_id") @db.Uuid
    courseId        String?              @map("course_id") @db.Uuid
    topicId         String?              @map("topic_id") @db.Uuid
    quizAttemptId   String?              @map("quiz_attempt_id") @db.Uuid
    eventType       PerformanceEventType @map("event_type")
    masteryScore    Float?               @map("mastery_score")
    durationSeconds Int?                 @map("duration_seconds")
    metadata        Json?                @db.JsonB
    occurredAt      DateTime             @default(now()) @map("occurred_at") @db.Timestamptz(3)
    createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    user         User         @relation("PerformanceLogUser", fields: [userId], references: [id], onDelete: Cascade)
    topic        Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
    quizAttempt  QuizAttempt? @relation(fields: [quizAttemptId], references: [id], onDelete: SetNull)

    @@index([organizationId])
    @@index([userId])
    @@index([organizationId, userId])
    @@index([topicId])
    @@index([eventType])
    @@index([organizationId, occurredAt])
    @@map("performance_log")
}
